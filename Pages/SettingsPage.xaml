<Page
    x:Class="IntuneTools.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="Settings"
                   HorizontalAlignment="Center"
                   FontSize="36"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Intro paragraph: explains what 'source' vs 'destination' actually mean. -->
        <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="WrapWholeWords"
                   MaxWidth="780"
                   Opacity="0.85">
            Configure the tenants this app talks to. The
            <Run FontWeight="SemiBold">Source</Run> tenant is used by every page that reads or modifies a tenant
            (Cleanup, Renaming, Assignment, Manage Assignments, Audit Log, JSON, and the source side of Import).
            The <Run FontWeight="SemiBold">Destination</Run> tenant is only used when copying content from Import.
            You can sign into one or both at any time, and swap them with a single click.
        </TextBlock>

        <!-- Source Tenant card -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,24,0,0">
            <StackPanel Spacing="12">
                <TextBlock Text="Source Tenant"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <controls:InfoBar
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Title="Usage"
                    Message="Used for Cleanup, Renaming, Assignment, and as the source when exporting content." />

                <!-- Status pill: shows signed-in/signed-out state with theme-aware colors. -->
                <Border x:Name="SourceStatusPill"
                        Style="{StaticResource TenantStatusPillStyle}"
                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Image x:Name="SourceLoginStatusImage"
                               Width="16"
                               Height="16"
                               Source="/Assets/RedCross.png"/>
                        <TextBlock x:Name="SourceLoginStatusText"
                                   Text="Not signed in"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Tenant detail (id / domain), only shown when signed in. -->
                <StackPanel x:Name="SourceTenantDetailPanel" Visibility="Collapsed" Spacing="2">
                    <TextBlock Text="Tenant ID" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="SourceTenantIdText"
                               FontFamily="Consolas"
                               FontSize="12"
                               IsTextSelectionEnabled="True"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="SourceLoginButton"
                            AutomationProperties.Name="Sign in to source tenant"
                            Content="Login"
                            Width="120"
                            Click="SourceLoginButton_Click"
                            ToolTipService.ToolTip="Sign in to a tenant interactively (opens a browser window)."/>
                    <Button x:Name="SourceSignOutButton"
                            AutomationProperties.Name="Sign out from source tenant"
                            Content="Sign out"
                            Width="120"
                            IsEnabled="False"
                            Click="SourceSignOutButton_Click"
                            ToolTipService.ToolTip="Clear cached source-tenant credentials. Disabled when not signed in."/>
                    <Button x:Name="SourceViewPermissionsButton"
                            AutomationProperties.Name="View source tenant permissions"
                            Content="View Permissions"
                            Width="140"
                            Click="SourceViewPermissionsButton_Click"
                            ToolTipService.ToolTip="See the granted Microsoft Graph permissions for the current source-tenant token."/>
                    <ProgressRing x:Name="SourceLoginProgress"
                                  Width="20"
                                  Height="20"
                                  IsActive="False"
                                  Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Swap Tenants button (between cards) -->
        <Button x:Name="SwapTenantsButton"
                AutomationProperties.Name="Swap source and destination tenants"
                Grid.Row="2" Grid.Column="1"
                Click="SwapTenantsButton_Click"
                ToolTipService.ToolTip="Swap source and destination tenants"
                VerticalAlignment="Center"
                Margin="16,24,16,0">
            <StackPanel Orientation="Vertical" Spacing="4">
                <!-- Sync glyph (E895) — chosen as a clearer "swap" affordance than the previous E8AB. -->
                <FontIcon Glyph="&#xE895;" FontSize="20"/>
                <TextBlock Text="Swap" FontSize="11"/>
            </StackPanel>
        </Button>

        <!-- Destination Tenant card -->
        <Border Grid.Row="2" Grid.Column="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,24,0,0">
            <StackPanel Spacing="12">
                <TextBlock Text="Destination Tenant"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <controls:InfoBar
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Title="Usage"
                    Message="Used only as the destination when importing content." />

                <Border x:Name="DestinationStatusPill"
                        Style="{StaticResource TenantStatusPillStyle}"
                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Image x:Name="DestinationLoginStatusImage"
                               Width="16"
                               Height="16"
                               Source="/Assets/RedCross.png"/>
                        <TextBlock x:Name="DestinationLoginStatusText"
                                   Text="Not signed in"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="DestinationTenantDetailPanel" Visibility="Collapsed" Spacing="2">
                    <TextBlock Text="Tenant ID" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="DestinationTenantIdText"
                               FontFamily="Consolas"
                               FontSize="12"
                               IsTextSelectionEnabled="True"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="DestinationLoginButton"
                            AutomationProperties.Name="Sign in to destination tenant"
                            Content="Login"
                            Width="120"
                            Click="DestinationLoginButton_Click"
                            ToolTipService.ToolTip="Sign in to a tenant interactively (opens a browser window)."/>
                    <Button x:Name="DestinationSignOutButton"
                            AutomationProperties.Name="Sign out from destination tenant"
                            Content="Sign out"
                            Width="120"
                            IsEnabled="False"
                            Click="DestinationSignOutButton_Click"
                            ToolTipService.ToolTip="Clear cached destination-tenant credentials. Disabled when not signed in."/>
                    <Button x:Name="DestinationViewPermissionsButton"
                            AutomationProperties.Name="View destination tenant permissions"
                            Content="View Permissions"
                            Width="140"
                            Click="DestinationViewPermissionsButton_Click"
                            ToolTipService.ToolTip="See the granted Microsoft Graph permissions for the current destination-tenant token."/>
                    <ProgressRing x:Name="DestinationLoginProgress"
                                  Width="20"
                                  Height="20"
                                  IsActive="False"
                                  Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer action -->
        <StackPanel Grid.Row="3" Grid.ColumnSpan="3"
                    HorizontalAlignment="Center"
                    Margin="0,24,0,0">
            <Button Content="Open Log File Location"
                    Click="OpenLogFileLocation_Click"
                    Width="220"/>
        </StackPanel>
    </Grid>
</Page>
