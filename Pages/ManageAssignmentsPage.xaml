<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.ManageAssignmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Migrated to the unified UI standard (see docs/UI_STANDARD.md).
        Layout contract:
            Row 0  Header (title, subtitle, status InfoBars)
            Row 1  Toolbar cards (search/staging + assignment actions)
            Row 2  Main content (DataGrid | splitter | side panel)
    -->
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="{StaticResource PageHeaderBottomMargin}">
            <TextBlock Text="Manage Assignments"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>
            <TextBlock Text="View and remove group assignments from policies and configurations."
                       Style="{StaticResource PageSubtitleTextBlockStyle}"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,12,0,0"/>
            <!-- Operation Status Bar - provides visual feedback during bulk operations -->
            <InfoBar x:Name="OperationStatusBar"
                     Severity="Informational"
                     IsClosable="True"
                     IsOpen="False"
                     Margin="0,8,0,0">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressRing x:Name="OperationProgressRing"
                                      IsActive="False"
                                      Width="20"
                                      Height="20"
                                      Visibility="Collapsed"/>
                        <ProgressBar x:Name="OperationProgressBar"
                                     Width="200"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

        <!-- ===== Toolbar Cards Row ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="{StaticResource PageSectionSpacing}" Margin="0,0,0,16">

            <!-- Search & Staging Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Search &amp; Staging"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox x:Name="InputTextBox"
                                 PlaceholderText="Enter search query..."
                                 Width="250"
                                 VerticalAlignment="Center"/>
                        <AppBarButton x:Name="SearchButton" Icon="Find" Label="Search" Click="SearchButton_Click" ToolTipService.ToolTip="Search for specific items."/>
                        <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all assignable items."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                        <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Assignment Actions Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Assignment Actions"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <AppBarButton x:Name="ViewAssignmentsButton" Label="Manage Assignments" Click="ViewAssignmentsButton_Click" ToolTipService.ToolTip="View, inspect, and remove assignments for selected items.">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE71D;"/>
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== Main Content Row ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="340" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Informational"
                         Title="Assignment Manager"
                         Message="Select items and use 'View Assignments' to inspect their group assignments, or 'Remove Assignments' to clear them."
                         IsClosable="True"
                         Margin="0,0,12,12"/>

                <controls:DataGrid Grid.Row="1"
                                   x:Name="AssignmentsDataGrid"
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="AssignmentsDataGrid_Sorting">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="2"
                        x:Name="LoadingOverlay"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                        Visibility="Collapsed"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="15">
                        <ProgressRing x:Name="LoadingProgressRing"
                                      IsActive="True"
                                      Width="50"
                                      Height="50"/>
                        <TextBlock x:Name="LoadingStatusText"
                                   Text="Loading..."
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimestampText}"
                                           Style="{StaticResource LogTimestampTextBlockStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LevelIndicator}"
                                           Foreground="{Binding Foreground}"
                                           Style="{StaticResource LogLevelTextBlockStyle}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Foreground}"
                                           Style="{StaticResource LogMessageTextBlockStyle}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
