<utilities:BaseMultiTenantPage
    x:Class="IntuneTools.Pages.AuditLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:utilities="using:IntuneTools.Utilities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Summary cards -->
            <RowDefinition Height="*"/>
            <!-- Audit events list + Log console -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Audit Log"
                       HorizontalAlignment="Left"
                       FontSize="38"
                       FontWeight="Bold"/>
            <TextBlock Text="Review recent Intune changes — who made them and what was done."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="14"
                       Margin="0,4,0,0"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,8,0,0"/>
            <InfoBar x:Name="OperationStatusBar"
                     Severity="Informational"
                     IsClosable="True"
                     IsOpen="False"
                     Margin="0,8,0,0">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressRing x:Name="OperationProgressRing"
                                      IsActive="False"
                                      Width="20"
                                      Height="20"
                                      Visibility="Collapsed"/>
                        <ProgressBar x:Name="OperationProgressBar"
                                     Width="200"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Time range:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <ComboBox x:Name="DaysComboBox"
                              Width="180"
                              SelectedIndex="0"
                              SelectionChanged="DaysComboBox_SelectionChanged">
                        <ComboBoxItem Content="Last 1 day" Tag="1"/>
                        <ComboBoxItem Content="Last 3 days" Tag="3"/>
                        <ComboBoxItem Content="Last 7 days" Tag="7"/>
                        <ComboBoxItem Content="Last 14 days" Tag="14"/>
                        <ComboBoxItem Content="Last 30 days" Tag="30"/>
                        <ComboBoxItem Content="Custom range…" Tag="custom"/>
                    </ComboBox>
                    <!-- Custom date range pickers — only shown when 'Custom range…' is chosen. -->
                    <StackPanel x:Name="CustomRangePanel"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <CalendarDatePicker x:Name="CustomFromPicker"
                                             AutomationProperties.Name="Custom range from"
                                             PlaceholderText="From"
                                             ToolTipService.ToolTip="Start of the custom range (inclusive)."/>
                        <TextBlock Text="→" VerticalAlignment="Center" Opacity="0.7"/>
                        <CalendarDatePicker x:Name="CustomToPicker"
                                             AutomationProperties.Name="Custom range to"
                                             PlaceholderText="To"
                                             ToolTipService.ToolTip="End of the custom range (inclusive)."/>
                    </StackPanel>
                    <AppBarButton x:Name="LoadButton"
                                  Icon="Refresh"
                                  Label="Load Audit Events"
                                  Click="LoadButton_Click"
                                  IsEnabled="False"
                                  ToolTipService.ToolTip="Load audit events for the selected range. Requires a signed-in source tenant."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="ExportCsvButton"
                                  Label="Export to CSV"
                                  Click="ExportCsvButton_Click"
                                  IsEnabled="False"
                                  ToolTipService.ToolTip="Export the currently filtered events to a CSV file. Disabled until events are loaded.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xEDE1;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="ExportReportButton"
                                  Label="Export Report"
                                  Click="ExportReportButton_Click"
                                  IsEnabled="False"
                                  ToolTipService.ToolTip="Export an HTML report including summary cards. Disabled until events are loaded.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE9D9;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="ClearLogButton"
                                  Icon="Delete"
                                  Label="Clear Log"
                                  Click="ClearLogButton_Click"
                                  ToolTipService.ToolTip="Clear the page log console."/>
                </StackPanel>
                <!-- Filter row: search text + actor filter (client-side). Always visible so users
                     know filtering is available even before loading. Filter inputs are disabled
                     until events are loaded. -->
                <StackPanel x:Name="FilterPanel"
                            Orientation="Horizontal"
                            Spacing="12"
                            Visibility="Visible">
                    <TextBlock Text="Filter:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <AutoSuggestBox x:Name="SearchTextBox"
                                    AutomationProperties.Name="Audit log filter text"
                                    PlaceholderText="Search activity, category, result, component, resource..."
                                    QueryIcon="Filter"
                                    Width="360"
                                    TextChanged="SearchTextBox_TextChanged"
                                    IsEnabled="False"/>
                    <TextBlock Text="Actor:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <ComboBox x:Name="ActorFilterComboBox"
                              AutomationProperties.Name="Filter by actor"
                              Width="240"
                              IsEnabled="False"
                              SelectionChanged="ActorFilterComboBox_SelectionChanged"/>
                    <Button x:Name="ClearFiltersButton"
                            Content="Clear filters"
                            IsEnabled="False"
                            Click="ClearFiltersButton_Click"/>
                    <TextBlock x:Name="FilterResultCountText"
                               VerticalAlignment="Center"
                               Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Summary Cards -->
        <Grid x:Name="SummaryCardsPanel" Grid.Row="2" ColumnSpacing="16" Margin="0,0,0,16" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Events -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Events" FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="TotalEventsText" Text="0" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Unique Actors -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Unique Actors" FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="UniqueActorsText" Text="0" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Activity Categories -->
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Categories" FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="CategoriesText" Text="0" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Success / Failure -->
            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Success / Failure" FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="SuccessFailureText" Text="0 / 0" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content: Audit List + Log Console -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Audit Events DataGrid -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Audit Events" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <!-- Changes By Actor Summary -->
                <Border x:Name="ActorSummaryPanel" Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12"
                        Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Changes by Actor" FontSize="14" FontWeight="SemiBold"/>
                        <ListView x:Name="ActorSummaryList"
                                  SelectionMode="None"
                                  MaxHeight="120">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ActorName}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CountText}" FontSize="13"
                                                   FontWeight="SemiBold" Opacity="0.8" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <controls:DataGrid x:Name="AuditDataGrid"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True"
                                       CanUserSortColumns="True"
                                       GridLinesVisibility="Horizontal"
                                       SelectionMode="Single"
                                       SelectionChanged="AuditDataGrid_SelectionChanged">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Date/Time" Binding="{Binding ActivityDateTimeFormatted}" Width="140"/>
                            <controls:DataGridTextColumn Header="Actor" Binding="{Binding ActorDisplayName}" Width="180"/>
                            <controls:DataGridTextColumn Header="Activity" Binding="{Binding ActivityDisplayName}" Width="*"/>
                            <controls:DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="140"/>
                            <controls:DataGridTextColumn Header="Result" Binding="{Binding ResultText}" Width="80"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>

                    <!-- Empty state shown before any load, or when filters yield 0 results. -->
                    <StackPanel x:Name="AuditEmptyState"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6"
                                IsHitTestVisible="False">
                        <FontIcon Glyph="&#xEA37;" FontSize="32" Opacity="0.5" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AuditEmptyStateTitle"
                                   Text="No audit events loaded"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Opacity="0.75"/>
                        <TextBlock x:Name="AuditEmptyStateBody"
                                   Text="Pick a time range above and click 'Load Audit Events'."
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Opacity="0.6"
                                   TextWrapping="WrapWholeWords"
                                   MaxWidth="360"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Log Console Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimestampText}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LevelIndicator}"
                                           Foreground="{Binding Foreground}"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Foreground}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="4" Background="{ThemeResource SystemControlAcrylicWindowBrush}" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing x:Name="LoadingProgressRing" IsActive="False" Width="48" Height="48"/>
                <TextBlock x:Name="LoadingStatusText" Text="Loading..." FontSize="16"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LoadingProgressDetail" Text="" FontSize="13"
                           Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                <Button x:Name="CancelLoadButton" Content="Cancel" Click="CancelLoadButton_Click"
                        HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</utilities:BaseMultiTenantPage>
