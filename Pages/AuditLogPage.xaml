<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseMultiTenantPage
    x:Class="IntuneTools.Pages.AuditLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:utilities="using:IntuneTools.Utilities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Migrated to the unified UI standard (see docs/UI_STANDARD.md).
        Layout contract:
            Row 0  Header (title, subtitle, status InfoBars)
            Row 1  Toolbar card (time range + actions)
            Row 2  Summary stat cards (Total Events, Unique Actors, ...)
            Row 3  Main content (Audit events DataGrid | Log console)
    -->
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="{StaticResource PageHeaderBottomMargin}">
            <TextBlock Text="Audit Log"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>
            <TextBlock Text="Review recent Intune changes — who made them and what was done."
                       Style="{StaticResource PageSubtitleTextBlockStyle}"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,12,0,0"/>
            <!-- Operation Status Bar - shared UserControl -->
            <utilities:OperationStatusBar x:Name="OperationStatusBar" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ===== Toolbar Card Row ===== -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="{StaticResource PageSectionSpacing}"
                    Margin="0,0,0,16">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Audit Query"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Time range:"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="DaysComboBox"
                                  Width="180"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Last 1 day" Tag="1"/>
                            <ComboBoxItem Content="Last 3 days" Tag="3"/>
                            <ComboBoxItem Content="Last 7 days" Tag="7"/>
                            <ComboBoxItem Content="Last 14 days" Tag="14"/>
                            <ComboBoxItem Content="Last 30 days" Tag="30"/>
                        </ComboBox>
                        <AppBarButton x:Name="LoadButton"
                                      Icon="Refresh"
                                      Label="Load Audit Events"
                                      Click="LoadButton_Click"
                                      IsEnabled="False"/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ExportCsvButton"
                                      Label="Export to CSV"
                                      Click="ExportCsvButton_Click"
                                      IsEnabled="False">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xEDE1;"/>
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="ExportReportButton"
                                      Label="Export Report"
                                      Click="ExportReportButton_Click"
                                      IsEnabled="False">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE9D9;"/>
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="ClearLogButton"
                                      Icon="Delete"
                                      Label="Clear Log"
                                      Click="ClearLogButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== Summary Cards ===== -->
        <Grid x:Name="SummaryCardsPanel"
              Grid.Row="2"
              ColumnSpacing="{StaticResource PageSectionSpacing}"
              Margin="0,0,0,16"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Events -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Total Events"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <TextBlock x:Name="TotalEventsText"
                               Text="0"
                               Style="{StaticResource StatValueTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Unique Actors -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Unique Actors"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <TextBlock x:Name="UniqueActorsText"
                               Text="0"
                               Style="{StaticResource StatValueTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Activity Categories -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Categories"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <TextBlock x:Name="CategoriesText"
                               Text="0"
                               Style="{StaticResource StatValueTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <!-- Success / Failure -->
            <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Success / Failure"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <TextBlock x:Name="SuccessFailureText"
                               Text="0 / 0"
                               Style="{StaticResource StatValueTextBlockStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Main Content: Audit List + Log Console ===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Audit Events DataGrid -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Audit Events"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                <!-- Changes By Actor Summary -->
                <Border x:Name="ActorSummaryPanel"
                        Grid.Row="1"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Changes by Actor"
                                   Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                        <ListView x:Name="ActorSummaryList"
                                  SelectionMode="None"
                                  MaxHeight="120"
                                  ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ActorName}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CountText}"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.8"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <controls:DataGrid Grid.Row="2"
                                   x:Name="AuditDataGrid"
                                   AutoGenerateColumns="False"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   GridLinesVisibility="Horizontal"
                                   SelectionMode="Single"
                                   SelectionChanged="AuditDataGrid_SelectionChanged">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Date/Time" Binding="{Binding ActivityDateTimeFormatted}" Width="140"/>
                        <controls:DataGridTextColumn Header="Actor" Binding="{Binding ActorDisplayName}" Width="180"/>
                        <controls:DataGridTextColumn Header="Activity" Binding="{Binding ActivityDisplayName}" Width="*"/>
                        <controls:DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="140"/>
                        <controls:DataGridTextColumn Header="Result" Binding="{Binding ResultText}" Width="80"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Grid>

            <!-- Log Console Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}"
                          ItemTemplate="{StaticResource LogConsoleItemTemplate}"/>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#80000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing x:Name="LoadingProgressRing" IsActive="False" Width="48" Height="48"/>
                <TextBlock x:Name="LoadingStatusText" Text="Loading..." FontSize="16"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LoadingProgressDetail" Text="" FontSize="13"
                           Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                <Button x:Name="CancelLoadButton" Content="Cancel" Click="CancelLoadButton_Click"
                        HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</utilities:BaseMultiTenantPage>
