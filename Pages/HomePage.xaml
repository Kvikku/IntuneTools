<Page
    x:Class="IntuneTools.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Migrated to the unified UI standard (see docs/UI_STANDARD.md).
        Home is a special-case landing page (not the three-row data layout),
        so per the standard it adopts CardBorderStyle for the hero/feature
        cards and the shared typography styles (PageTitleTextBlockStyle,
        PageSubtitleTextBlockStyle, SidePanelHeaderTextBlockStyle) for the
        title and section headings.
    -->
    <Grid Margin="{StaticResource PageRootMargin}">
        <ScrollViewer>
            <StackPanel Spacing="24">

                <!-- Hero Banner -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Welcome to InToolz"
                                   Style="{StaticResource PageTitleTextBlockStyle}"/>
                        <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}"
                                   MaxWidth="900">
                            Simplify bulk Intune management — assign, rename, clean up, and migrate configurations between tenants.
                        </TextBlock>

                        <!-- Version status indicator -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="0,4,0,0">
                            <Ellipse x:Name="VersionStatusIndicator" Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="VersionStatusBrush" Color="Gray"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="VersionStatusText"
                                       Text="Checking version..."
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" x:Name="UpdateButtonsPanel" Visibility="Collapsed" Spacing="6">
                                <Button x:Name="OpenGitHubButton"
                                        Content="Open GitHub"
                                        Click="OpenGitHubButton_Click"
                                        VerticalAlignment="Center"/>
                                <Button x:Name="OpenStoreButton"
                                        Content="Open in Store"
                                        Click="OpenStoreButton_Click"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <StackPanel>
                    <TextBlock Text="Get started"
                               Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>
                    <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Click="QuickAction_Assignment_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="AllApps" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Assignment"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Assign policies and apps to groups in bulk."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            Click="QuickAction_Import_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Import" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Import"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Export and import configurations between tenants."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Click="QuickAction_Cleanup_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Delete" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Cleanup"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Remove policies, scripts, and profiles in bulk."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Click="QuickAction_Renaming_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Rename" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Renaming"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Rename objects with customizable prefixes."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Click="QuickAction_Json_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE8AB;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="JSON"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Import from and export to JSON files."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Click="QuickAction_ManageAssignments_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE71D;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Manage Assignments"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="View and remove group assignments from content."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="6"
                            Click="QuickAction_AuditLog_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Audit Log"
                                       Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                            <TextBlock Text="Review recent changes and who made them."
                                       Style="{StaticResource FeatureCardDescriptionTextBlockStyle}"/>
                        </StackPanel>
                    </Button>
                </Grid>
                </StackPanel>

                <!-- Dashboard Row: Connection + Time Saved -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Connection Info (clickable → Settings) -->
                    <Button Grid.Column="0"
                            Click="QuickAction_Settings_Click"
                            Style="{StaticResource FeatureCardButtonStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Connection"
                                       Style="{StaticResource SidePanelHeaderTextBlockStyle}"
                                       Margin="0"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <Image x:Name="LoginStatusImage" Width="24" Height="24" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Tenant"
                                               Style="{StaticResource MutedCaptionTextBlockStyle}"/>
                                    <TextBlock x:Name="TenantNameText"
                                               Text="Not Connected"
                                               Style="{StaticResource FeatureCardTitleTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="SignInHintText"
                                       Text="Sign in via Settings to get started →"
                                       Style="{StaticResource MutedCaptionTextBlockStyle}"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Time Saved -->
                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Time Saved"
                                       Style="{StaticResource SidePanelHeaderTextBlockStyle}"
                                       Margin="0"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                <TextBlock x:Name="TimeSavedMinutesText"
                                           Text="0"
                                           Style="{StaticResource StatHeroValueTextBlockStyle}"/>
                                <TextBlock Text="minutes saved"
                                           Style="{StaticResource StatHeroLabelTextBlockStyle}"/>
                            </StackPanel>
                            <ProgressBar x:Name="TimeSavedProgress"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="1000"
                                         Value="0"
                                         CornerRadius="3"/>
                            <TextBlock Text="Estimate based on recorded actions and typical manual completion times."
                                       TextWrapping="WrapWholeWords"
                                       Style="{StaticResource MutedCaptionTextBlockStyle}"/>

                            <StackPanel x:Name="TimeSavedBreakdownPanel" Spacing="4" Visibility="Collapsed">
                                <TextBlock Text="Breakdown"
                                           Style="{StaticResource SubsectionLabelTextBlockStyle}"/>
                                <StackPanel x:Name="RenamedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="RenamedItemsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items renamed / descriptions updated"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="AssignedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="AssignedItemsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items assigned"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="DeletedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="DeletedItemsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items deleted"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="ImportedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="ImportedItemsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items imported"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="CheckedAssignmentsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="CheckedAssignmentsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items checked for assignments"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="JsonExportedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="JsonExportedItemsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="items exported to JSON"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="AuditLogsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="AuditLogsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="audit logs retrieved"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="ManagedAssignmentsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="ManagedAssignmentsCountText" Text="0"
                                               Style="{StaticResource StatBreakdownValueTextBlockStyle}"/>
                                    <TextBlock Text="assignments managed"
                                               Style="{StaticResource StatBreakdownLabelTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Resources -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Resources"
                                   Style="{StaticResource SidePanelHeaderTextBlockStyle}"
                                   Margin="0"/>
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE736;" FontSize="18" Opacity="0.7"/>
                                <TextBlock Text="Documentation" VerticalAlignment="Center"/>
                                <HyperlinkButton x:Name="GitHubLink"
                                                 Content="View on GitHub"
                                                 NavigateUri="https://github.com/Kvikku/IntuneTools"
                                                 Click="GitHubLink_Click"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xED15;" FontSize="18" Opacity="0.7"/>
                                <TextBlock Text="Feedback &amp; Issues" VerticalAlignment="Center"/>
                                <HyperlinkButton x:Name="GitHubIssuesLink"
                                                 Content="Submit on GitHub"
                                                 NavigateUri="https://github.com/Kvikku/IntuneTools/issues"
                                                 Click="GitHubLink_Click"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
