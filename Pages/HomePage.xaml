<Page
    x:Class="IntuneTools.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <ScrollViewer>
            <StackPanel Padding="40" Spacing="24">

                <!-- Hero Banner -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="32">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Welcome to InToolz"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"/>
                        <TextBlock TextWrapping="WrapWholeWords"
                                   FontSize="16"
                                   Opacity="0.85"
                                   MaxWidth="900"
                                   HorizontalAlignment="Left">
                            Simplify bulk Intune management — assign, rename, clean up, and migrate configurations between tenants.
                        </TextBlock>

                        <!-- Version status indicator -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="0,4,0,0">
                            <ProgressRing x:Name="VersionStatusProgressRing"
                                          Width="14" Height="14"
                                          IsActive="True"
                                          VerticalAlignment="Center"/>
                            <Ellipse x:Name="VersionStatusIndicator" Width="10" Height="10" VerticalAlignment="Center" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="VersionStatusBrush" Color="Gray"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="VersionStatusText"
                                       Text="Checking version..."
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" x:Name="UpdateButtonsPanel" Visibility="Collapsed" Spacing="6">
                                <Button x:Name="OpenGitHubButton"
                                        Content="Open GitHub"
                                        Click="OpenGitHubButton_Click"
                                        VerticalAlignment="Center"/>
                                <Button x:Name="OpenStoreButton"
                                        Content="Open in Store"
                                        Click="OpenStoreButton_Click"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <InfoBar x:Name="SignInFirstInfoBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Warning"
                         Title="Sign in first"
                         Message="Go to Settings and sign in to a source tenant before using any features.">
                    <InfoBar.ActionButton>
                        <Button Content="Open Settings" Click="QuickAction_Settings_Click"/>
                    </InfoBar.ActionButton>
                </InfoBar>
                <TextBlock Text="Get started" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,-8"/>
                <Grid x:Name="QuickActionsGrid" ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Click="QuickAction_Assignment_Click"
                            AutomationProperties.Name="Open Assignment page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="AllApps" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Assignment" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Assign policies and apps to groups in bulk."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            Click="QuickAction_Import_Click"
                            AutomationProperties.Name="Open Import page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Import" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Import" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Export and import configurations between tenants."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Click="QuickAction_Cleanup_Click"
                            AutomationProperties.Name="Open Cleanup page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Delete" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Cleanup" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Remove policies, scripts, and profiles in bulk."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3"
                            Click="QuickAction_Renaming_Click"
                            AutomationProperties.Name="Open Renaming page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <SymbolIcon Symbol="Rename" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Renaming" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Rename objects with customizable prefixes."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Click="QuickAction_Json_Click"
                            AutomationProperties.Name="Open JSON page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE8AB;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="JSON" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Import from and export to JSON files."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5"
                            Click="QuickAction_ManageAssignments_Click"
                            AutomationProperties.Name="Open Manage Assignments page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE71D;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Manage Assignments" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="View and remove group assignments from content."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="6"
                            Click="QuickAction_AuditLog_Click"
                            AutomationProperties.Name="Open Audit Log page"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Audit Log" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Review recent changes and who made them."
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Dashboard Row: Connection + Time Saved -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Connection Info (clickable → Settings) -->
                    <Button Grid.Column="0"
                            Click="QuickAction_Settings_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="20"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Connection" FontSize="20" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <Image x:Name="LoginStatusImage" Width="24" Height="24" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Tenant" FontSize="13" Opacity="0.6"/>
                                    <TextBlock x:Name="TenantNameText" Text="Not Connected" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Time Saved -->
                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Time Saved" FontSize="20" FontWeight="SemiBold"/>
                                <Button Padding="4" Background="Transparent" BorderThickness="0"
                                        AutomationProperties.Name="About the time saved metric"
                                        ToolTipService.ToolTip="Estimated based on recorded actions and typical manual completion times in Intune. Each action type contributes a fixed seconds-saved value (rename ~20s, assign ~30s, delete ~10s, import ~90s, etc.).">
                                    <FontIcon Glyph="&#xE9CE;" FontSize="14" Opacity="0.6"/>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                <TextBlock x:Name="TimeSavedMinutesText"
                                           Text="0"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="minutes saved"
                                           FontSize="16"
                                           Opacity="0.7"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ProgressBar x:Name="TimeSavedProgress"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="1000"
                                         Value="0"
                                         CornerRadius="3"/>
                            <TextBlock Text="Estimate based on recorded actions and typical manual completion times."
                                       TextWrapping="WrapWholeWords"
                                       FontSize="13"
                                       Opacity="0.6"/>

                            <StackPanel x:Name="TimeSavedBreakdownPanel" Spacing="4" Visibility="Collapsed">
                                <TextBlock Text="Breakdown" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <StackPanel x:Name="RenamedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="RenamedItemsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items renamed / descriptions updated" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="AssignedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="AssignedItemsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items assigned" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="DeletedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="DeletedItemsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items deleted" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="ImportedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="ImportedItemsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items imported" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="CheckedAssignmentsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="CheckedAssignmentsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items checked for assignments" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="JsonExportedItemsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="JsonExportedItemsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="items exported to JSON" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="AuditLogsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="AuditLogsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="audit logs retrieved" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                                <StackPanel x:Name="ManagedAssignmentsPanel" Orientation="Horizontal" Spacing="6" Visibility="Collapsed">
                                    <TextBlock x:Name="ManagedAssignmentsCountText" Text="0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="assignments managed" FontSize="13" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Activity -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Recent Activity" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Latest operation outcomes across pages."
                                   FontSize="13"
                                   Opacity="0.65"/>
                        <Grid MinHeight="120">
                            <ListView x:Name="RecentActivityListView"
                                      AutomationProperties.Name="Recent activity list"
                                      SelectionMode="None"
                                      MinHeight="120"
                                      MaxHeight="220">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="64"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimestampText}"
                                                       Opacity="0.7"
                                                       FontSize="12"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Status}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Message}"
                                                       TextWrapping="WrapWholeWords"
                                                       FontSize="13"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <!-- Empty state shown when there's no recorded activity yet. -->
                            <StackPanel x:Name="RecentActivityEmptyState"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="6"
                                        Visibility="Collapsed">
                                <FontIcon Glyph="&#xE9D9;" FontSize="28" Opacity="0.5"/>
                                <TextBlock Text="No recent activity yet"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Opacity="0.75"/>
                                <TextBlock Text="Run an action from one of the pages above and the result will appear here."
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Opacity="0.6"
                                           TextWrapping="WrapWholeWords"
                                           MaxWidth="320"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Resources -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Resources" FontSize="20" FontWeight="SemiBold"/>
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE736;" FontSize="18" Opacity="0.7"/>
                                <TextBlock Text="Documentation" VerticalAlignment="Center"/>
                                <HyperlinkButton x:Name="GitHubLink"
                                                 Content="View on GitHub"
                                                 NavigateUri="https://github.com/Kvikku/IntuneTools"
                                                 Click="GitHubLink_Click"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xED15;" FontSize="18" Opacity="0.7"/>
                                <TextBlock Text="Feedback &amp; Issues" VerticalAlignment="Center"/>
                                <HyperlinkButton x:Name="GitHubIssuesLink"
                                                 Content="Submit on GitHub"
                                                 NavigateUri="https://github.com/Kvikku/IntuneTools/issues"
                                                 Click="GitHubLink_Click"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
