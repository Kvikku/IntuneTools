<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="{StaticResource PageHeaderBottomMargin}">
            <TextBlock Text="Intune Cleanup"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>
            <TextBlock Text="Bulk delete policies and configurations from a tenant."
                       Style="{StaticResource PageSubtitleTextBlockStyle}"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,12,0,0"/>
            <utilities:OperationStatusBar x:Name="OperationStatusBar" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ===== Mode Selector ===== -->
        <ctk:Segmented Grid.Row="1"
                       x:Name="CleanupModeSegmented"
                       SelectionMode="Single"
                       SelectedIndex="0"
                       SelectionChanged="CleanupModeSegmented_SelectionChanged"
                       Margin="0,0,0,16">
            <ctk:SegmentedItem Content="Delete Content">
                <ctk:SegmentedItem.Icon>
                    <FontIcon Glyph="&#xE74D;"/>
                </ctk:SegmentedItem.Icon>
            </ctk:SegmentedItem>
            <ctk:SegmentedItem Content="Find Duplicates">
                <ctk:SegmentedItem.Icon>
                    <FontIcon Glyph="&#xE8C8;"/>
                </ctk:SegmentedItem.Icon>
            </ctk:SegmentedItem>
        </ctk:Segmented>

        <!-- ===== Main Content Row ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="340" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Delete or Duplicates -->
            <Grid Grid.Column="0">

                <!-- ── DELETE PANEL ── -->
                <Grid x:Name="DeletePanel" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="{StaticResource PageSectionSpacing}" Margin="0,0,0,16">

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Search &amp; Staging"
                                           Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBox x:Name="InputTextBox"
                                             PlaceholderText="Enter search query..."
                                             Width="250"
                                             VerticalAlignment="Center"/>
                                    <AppBarButton x:Name="SearchButton" Icon="Find" Label="Search" Click="SearchButton_Click" ToolTipService.ToolTip="Search for specific items."/>
                                    <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items."/>
                                    <AppBarButton x:Name="FindUnassignedButton" Label="Find Unassigned" Click="FindUnassignedButton_Click" ToolTipService.ToolTip="Find content with no group assignments.">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE7B3;"/>
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                                    <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="ExportCsvButton" Icon="Save" Label="Export CSV" Click="ExportCsvButton_Click" ToolTipService.ToolTip="Export the current list to a CSV file."/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Destructive Action"
                                           Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="DeleteButton"
                                            Click="DeleteButton_Click"
                                            ToolTipService.ToolTip="Permanently delete all staged items."
                                            Style="{StaticResource DestructiveActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="White"/>
                                            <TextBlock Text="Delete All" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Staging InfoBar -->
                    <InfoBar Grid.Row="1"
                             IsOpen="True"
                             Severity="Warning"
                             Title="Staging Area"
                             Message="This grid acts as a staging area. All items listed below will be permanently deleted. Use the 'Clear' buttons to exclude items you do not wish to delete."
                             IsClosable="True"
                             Margin="0,0,12,12"/>

                    <!-- Cleanup DataGrid -->
                    <controls:DataGrid Grid.Row="2"
                                       x:Name="CleanupDataGrid"
                                       AutoGenerateColumns="False"
                                       SelectionMode="Extended"
                                       Margin="0,0,12,0"
                                       IsReadOnly="True"
                                       CanUserSortColumns="True"
                                       CanUserReorderColumns="False"
                                       Sorting="CleanupDataGrid_Sorting">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                            <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                            <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                            <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                            <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>

                    <utilities:LoadingOverlay Grid.RowSpan="3" x:Name="LoadingOverlay"/>
                </Grid>

                <!-- ── DUPLICATES PANEL ── -->
                <Grid x:Name="DuplicatesPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Duplicates Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="{StaticResource PageSectionSpacing}" Margin="0,0,0,16">

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Scan &amp; Review"
                                           Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <AppBarButton x:Name="ScanDuplicatesButton" Label="Scan" Click="ScanDuplicatesButton_Click" ToolTipService.ToolTip="Scan all content types for duplicate names.">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE8C8;"/>
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="AutoSelectOlderButton" Label="Auto-select Older" Click="AutoSelectOlderButton_Click" ToolTipService.ToolTip="Automatically select the older item in each duplicate pair.">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE8CB;"/>
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton x:Name="ClearDuplicateSelectionButton" Icon="Remove" Label="Clear Selected" Click="ClearDuplicateSelectionButton_Click" ToolTipService.ToolTip="Remove selected items from the results."/>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="DuplicatesClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                                    <AppBarSeparator/>
                                    <AppBarButton x:Name="DuplicatesExportCsvButton" Icon="Save" Label="Export CSV" Click="DuplicatesExportCsvButton_Click" ToolTipService.ToolTip="Export the duplicates list to a CSV file."/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Destructive Action"
                                           Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="DeleteDuplicatesButton"
                                            Click="DeleteDuplicatesButton_Click"
                                            ToolTipService.ToolTip="Permanently delete selected duplicates."
                                            Style="{StaticResource DestructiveActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="White"/>
                                            <TextBlock Text="Delete Selected" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Duplicates InfoBar -->
                    <InfoBar Grid.Row="1"
                             IsOpen="True"
                             Severity="Informational"
                             Title="Duplicate Detection"
                             Message="Scan to find policies with identical names. Use 'Auto-select Older' to mark the older item in each pair, then review and delete."
                             IsClosable="True"
                             Margin="0,0,12,12"/>

                    <!-- Duplicates DataGrid -->
                    <controls:DataGrid Grid.Row="2"
                                       x:Name="DuplicatesDataGrid"
                                       AutoGenerateColumns="False"
                                       SelectionMode="Extended"
                                       Margin="0,0,12,0"
                                       IsReadOnly="True"
                                       CanUserSortColumns="True"
                                       CanUserReorderColumns="False"
                                       Sorting="DuplicatesDataGrid_Sorting">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                            <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                            <controls:DataGridTextColumn Header="Created" Binding="{Binding CreatedDisplay}" Width="*"/>
                            <controls:DataGridTextColumn Header="Modified" Binding="{Binding ModifiedDisplay}" Width="*"/>
                            <controls:DataGridTextColumn Header="Assigned" Binding="{Binding AssignedDisplay}" Width="Auto"/>
                            <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>

                    <utilities:LoadingOverlay Grid.RowSpan="3" x:Name="DuplicatesLoadingOverlay"/>
                </Grid>
            </Grid>

            <!-- Resizable Splitter -->
            <ctk:GridSplitter Grid.Column="1"
                              Width="8"
                              ResizeBehavior="BasedOnAlignment"
                              ResizeDirection="Columns"
                              Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>
                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}"
                          ItemTemplate="{StaticResource LogConsoleItemTemplate}"/>
            </Grid>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
