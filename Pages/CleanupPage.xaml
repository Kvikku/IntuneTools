<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    xmlns:c="using:IntuneTools.Pages.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="F"      Invoked="FocusSearch_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="L"      Invoked="ListAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="A"      Invoked="SelectAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="A" Invoked="DeselectAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="Enter"  Invoked="PrimaryAction_Accelerator"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- CommandBar -->
            <RowDefinition Height="*"/>
            <!-- Data grid + Side panel -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <c:PageHeader Grid.Row="0"
                      Title="Intune Cleanup"
                      Subtitle="Bulk delete policies and configurations from a tenant."
                      InstructionSeverity="Warning"
                      InstructionText="1. Search or list all content to populate the staging grid.  2. Remove any items you do NOT want deleted.  3. Click 'Delete All' — this action is permanent and cannot be undone.">
            <c:PageHeader.ExtraContent>
                <StackPanel>
                    <InfoBar x:Name="TenantInfoBar"
                             Severity="Informational"
                             IsClosable="False"
                             IsOpen="False"
                             Margin="0,8,0,0"/>
                    <!-- Operation Status Bar - provides visual feedback during bulk operations -->
                    <InfoBar x:Name="OperationStatusBar"
                             Severity="Informational"
                             IsClosable="True"
                             IsOpen="False"
                             Margin="0,8,0,0">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <ProgressRing x:Name="OperationProgressRing"
                                              IsActive="False"
                                              Width="20"
                                              Height="20"
                                              Visibility="Collapsed"/>
                                <ProgressBar x:Name="OperationProgressBar"
                                             Width="200"
                                             IsIndeterminate="False"
                                             Visibility="Collapsed"/>
                                <Button x:Name="CancelOperationButton"
                                        Content="Cancel"
                                        Click="CancelOperationButton_Click"
                                        Visibility="Collapsed"
                                        ToolTipService.ToolTip="Cancel the currently running delete operation (already-deleted items will not be restored)."/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                </StackPanel>
            </c:PageHeader.ExtraContent>
        </c:PageHeader>

        <!-- Toolbar Cards Row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">

            <!-- Search & Staging Card -->
            <c:ToolbarCard HeaderText="Search &amp; Staging">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <AutoSuggestBox x:Name="InputTextBox"
                                    AutomationProperties.Name="Cleanup search query"
                                    PlaceholderText="Search by name..."
                                    Style="{StaticResource ToolbarSearchBoxStyle}"
                                    VerticalAlignment="Center"
                                    QuerySubmitted="InputTextBox_QuerySubmitted"/>
                    <AppBarButton x:Name="ListAllButton" AutomationProperties.Name="List all content" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items (Ctrl+L)."/>
                    <AppBarButton x:Name="FindUnassignedButton" Label="Find Unassigned" Click="FindUnassignedButton_Click" ToolTipService.ToolTip="Find content with no group assignments.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE7B3;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                    <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="SelectAllButton" Label="Select All" Click="SelectAllButton_Click" ToolTipService.ToolTip="Select all items in the staging grid.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8B3;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="DeselectAllButton" Label="Deselect All" Click="DeselectAllButton_Click" ToolTipService.ToolTip="Clear the grid selection.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE711;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <TextBlock x:Name="SelectionCountText"
                               Text="Selected: 0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="4,0,0,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </c:ToolbarCard>

            <!-- Delete Action Card -->
            <c:ToolbarCard HeaderText="Destructive Action">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="DeleteButton"
                            Click="DeleteButton_Click"
                            ToolTipService.ToolTip="Permanently delete all staged items (Ctrl+Enter)."
                            Style="{StaticResource DestructiveActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                            <TextBlock x:Name="DeleteButtonText" Text="Delete All" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </c:ToolbarCard>
        </StackPanel>

        <!-- Main Content Row -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="Auto"/>
                <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="200"/>
                <!-- Log panel -->
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- InfoBar -->
                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Warning"
                         Title="Staging Area"
                         Message="This grid acts as a staging area. All items listed below will be permanently deleted. Use the 'Clear' buttons to exclude items you do not wish to delete."
                         IsClosable="True"
                         Margin="0,0,12,12"/>
                
                <!-- DataGrid -->
                <controls:DataGrid Grid.Row="1"
                                   x:Name="CleanupDataGrid" 
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="CleanupDataGrid_Sorting"
                                   SelectionChanged="CleanupDataGrid_SelectionChanged">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Empty state shown when nothing has been loaded yet. -->
                <c:EmptyState x:Name="StagingEmptyState"
                              Grid.Row="1"
                              Glyph="&#xE74C;"
                              Title="Nothing staged for cleanup"
                              Message="Use Search, List All, or Find Unassigned to populate the grid (Ctrl+F to focus search, Ctrl+L to list all)."
                              Margin="0,0,12,0"/>

                <!-- Loading Overlay -->
                <c:LoadingOverlay x:Name="LoadingOverlay"
                                  Grid.RowSpan="2"
                                  StatusText="Loading..."/>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <c:LogConsole Grid.Column="2"
                          x:Name="LogConsole"
                          Margin="0,-20,0,0"
                          Entries="{x:Bind LogEntries, Mode=OneWay}"/>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
