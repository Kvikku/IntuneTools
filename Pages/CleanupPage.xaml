<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- CommandBar -->
            <RowDefinition Height="*"/>
            <!-- Data grid + Side panel -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Intune Cleanup"
                       HorizontalAlignment="Left"
                       FontSize="38"
                       FontWeight="Bold"/>
            <TextBlock Text="Bulk delete policies and configurations from a tenant."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="14"
                       Margin="0,4,0,0"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,8,0,0"/>
            <!-- Operation Status Bar - provides visual feedback during bulk operations -->
            <InfoBar x:Name="OperationStatusBar"
                     Severity="Informational"
                     IsClosable="True"
                     IsOpen="False"
                     Margin="0,8,0,0">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressRing x:Name="OperationProgressRing"
                                      IsActive="False"
                                      Width="20"
                                      Height="20"
                                      Visibility="Collapsed"/>
                        <ProgressBar x:Name="OperationProgressBar"
                                     Width="200"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

        <!-- Toolbar Cards Row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">

            <!-- Search & Staging Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Search &amp; Staging" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox x:Name="InputTextBox"
                                 PlaceholderText="Enter search query..."
                                 Width="250"
                                 VerticalAlignment="Center"/>
                        <AppBarButton x:Name="SearchButton" Icon="Find" Label="Search" Click="SearchButton_Click" ToolTipService.ToolTip="Search for specific items."/>
                        <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ContentTypesButton" Icon="Filter" Label="Content Types">
                            <AppBarButton.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel x:Name="ContentTypesPanel" Orientation="Vertical" MinWidth="300">
                                        <TextBlock Text="Content Types" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <CheckBox x:Name="OptionsAllCheckBox"
                                                  Content="Select all"
                                                  IsThreeState="False"
                                                  Checked="SelectAll_Checked"
                                                  Unchecked="SelectAll_Unchecked"
                                                  Indeterminate="SelectAll_Indeterminate"/>
                                        <CheckBox x:Name="SettingsCatalog" Content="Settings Catalog" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="DeviceCompliance" Content="Device Compliance" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="DeviceConfiguration" Content="Device Configuration" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="AppleBYODEnrollmentProfile" Content="Apple BYOD Enrollment Profile" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="Filters" Content="Filters" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="EntraGroups" Content="Entra Groups" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="PowerShellScript" Content="PowerShell Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="ProactiveRemediation" Content="Remediation Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="macOSShellScript" Content="macOS Shell Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsAutopilot" Content="Windows Autopilot" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsDriverUpdate" Content="Windows Driver Update" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsFeatureUpdate" Content="Windows Feature Update" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsQualityUpdatePolicy" Content="Windows Quality Update Policy" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsQualityUpdateProfile" Content="Windows Quality Update Profile" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="ConditionalAccess" Content="Conditional Access" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                    </StackPanel>
                                </Flyout>
                            </AppBarButton.Flyout>
                        </AppBarButton>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                        <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Delete Action Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Destructive Action" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="DeleteButton"
                                Click="DeleteButton_Click"
                                ToolTipService.ToolTip="Permanently delete all staged items."
                                Height="40"
                                Padding="16,0"
                                BorderBrush="#C42B1C"
                                Background="#C42B1C">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="White"/>
                                <TextBlock Text="Delete All" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Main Content Row -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="Auto"/>
                <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="200"/>
                <!-- Log panel -->
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- InfoBar -->
                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Warning"
                         Title="Staging Area"
                         Message="This grid acts as a staging area. All items listed below will be permanently deleted. Use the 'Clear' buttons to exclude items you do not wish to delete."
                         IsClosable="True"
                         Margin="0,0,12,12"/>
                
                <!-- DataGrid -->
                <controls:DataGrid Grid.Row="1"
                                   x:Name="CleanupDataGrid" 
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="CleanupDataGrid_Sorting">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="2"
                        x:Name="LoadingOverlay"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                        Visibility="Collapsed"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="15">
                        <ProgressRing x:Name="LoadingProgressRing"
                                      IsActive="True"
                                      Width="50"
                                      Height="50"/>
                        <TextBlock x:Name="LoadingStatusText"
                                   Text="Loading..."
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="2"
                  Margin="0,-20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimestampText}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LevelIndicator}"
                                           Foreground="{Binding Foreground}"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Foreground}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
