<utilities:BaseMultiTenantPage
    x:Class="IntuneTools.Pages.AssignmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    xmlns:utilities="using:IntuneTools.Utilities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Migrated to the unified UI standard (see docs/UI_STANDARD.md).
        Layout contract:
            Row 0  Header (title, subtitle, status InfoBars)
            Row 1  Toolbar cards (search/staging)
            Row 2  Main content (DataGrid | groups side panel | splitter | log panel)
    -->
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="{StaticResource PageHeaderBottomMargin}">
            <TextBlock Text="Intune Assignments"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>
            <TextBlock Text="Assign policies and apps to groups in bulk."
                       Style="{StaticResource PageSubtitleTextBlockStyle}"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,12,0,0"/>
            <!-- Operation Status Bar - shared UserControl -->
            <utilities:OperationStatusBar x:Name="OperationStatusBar" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ===== Toolbar Cards Row ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="{StaticResource PageSectionSpacing}" Margin="0,0,0,16">

            <!-- Search & Staging Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Search &amp; Staging"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <AutoSuggestBox x:Name="ContentSearchBox"
                                        PlaceholderText="Search by name..."
                                        QueryIcon="Find"
                                        Width="250"
                                        QuerySubmitted="ContentSearchBox_QuerySubmitted"
                                        TextChanged="ContentSearchBox_TextChanged"/>
                        <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all content for selected types."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ContentTypesButton" Icon="Filter" Label="Content Types">
                            <AppBarButton.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel x:Name="OptionsPanel" Orientation="Vertical" Spacing="2" MinWidth="300">
                                        <TextBlock Text="Content Types"
                                                   Style="{StaticResource SubsectionLabelTextBlockStyle}"/>
                                        <CheckBox x:Name="OptionsAllCheckBox"
                                                  Content="Select all"
                                                  IsThreeState="False"
                                                  Checked="SelectAll_Checked"
                                                  Unchecked="SelectAll_Unchecked"
                                                  Indeterminate="SelectAll_Indeterminate"/>
                                        <CheckBox x:Name="Application" Content="Applications" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="SettingsCatalog" Content="Settings Catalog" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="DeviceCompliance" Content="Device Compliance" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="EntraGroups" Content="Entra Groups" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="DeviceConfiguration" Content="Device Configuration" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="AppleBYODEnrollmentProfile" Content="Apple BYOD enrollment profile" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="Filters" Content="Filters" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="PowerShellScript" Content="PowerShell Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="ProactiveRemediation" Content="Remediation Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="macOSShellScript" Content="macOS Shell Scripts" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsAutopilot" Content="Windows Autopilot" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsDriverUpdate" Content="Windows Driver Update" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsFeatureUpdate" Content="Windows Feature Update" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsQualityUpdatePolicy" Content="Windows Quality Update Policy" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                        <CheckBox x:Name="WindowsQualityUpdateProfile" Content="Windows Quality Update Profile" Margin="24,0,0,0" Checked="Option_Checked" Unchecked="Option_Unchecked"/>
                                    </StackPanel>
                                </Flyout>
                            </AppBarButton.Flyout>
                        </AppBarButton>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="RemoveSelectedButton" Icon="Delete" Label="Remove Selected" Click="RemoveSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from the grid."/>
                        <AppBarButton x:Name="RemoveAllButton" Icon="Clear" Label="Remove All" Click="RemoveAllButton_Click" ToolTipService.ToolTip="Clear all items from the grid."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== Main Content Row ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="280" MinWidth="200"/>
                <!-- Assignment side panel -->
                <ColumnDefinition Width="Auto"/>
                <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="200"/>
                <!-- Log panel -->
            </Grid.ColumnDefinitions>

            <!-- DataGrid with loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <InfoBar x:Name="StagingAreaInfoBar"
                         Grid.Row="0"
                         IsOpen="True"
                         Severity="Informational"
                         Title="Staging Area"
                         Message="This grid acts as a staging area. All items listed below will be assigned to the selected groups. Use the 'Remove' buttons to exclude items you do not wish to assign."
                         IsClosable="True"
                         Margin="0,0,12,12"/>
                <controls:DataGrid Grid.Row="1"
                                   x:Name="AppDataGrid"
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="AppDataGrid_Sorting">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Loading Overlay - shared UserControl -->
                <utilities:LoadingOverlay Grid.RowSpan="2"
                                          x:Name="LoadingOverlay"/>
            </Grid>

            <!-- Assignment Side Panel -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,12,0">
                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="Assign to Groups"
                               Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                    <!-- Groups Section -->
                    <TextBlock Text="Groups"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
                        <TextBox x:Name="GroupSearchTextBox"
                                 PlaceholderText="Search groups..."
                                 Width="150"/>
                        <Button x:Name="GroupSearchButton"
                                Click="GroupSearchButton_Click"
                                ToolTipService.ToolTip="Search for a specific group.">
                            <FontIcon Glyph="&#xE721;" FontSize="14"/>
                        </Button>
                    </StackPanel>

                    <Button x:Name="GroupListAllButton"
                            Content="List all groups"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Left"
                            Click="GroupListAllButton_Click"/>

                    <controls:DataGrid x:Name="GroupDataGrid"
                                       AutoGenerateColumns="False"
                                       HeadersVisibility="Column"
                                       Height="160"
                                       SelectionMode="Extended"
                                       Margin="0,0,0,16"
                                       IsReadOnly="True"
                                       CanUserSortColumns="True"
                                       CanUserReorderColumns="False"
                                       Sorting="GroupDataGrid_Sorting">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Group Name" Binding="{Binding GroupName}" Width="2*"/>
                            <controls:DataGridTextColumn Header="ID" Binding="{Binding GroupId}" Width="*"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>

                    <!-- ASSIGN BUTTON - Primary action -->
                    <Button x:Name="AssignButton"
                            Click="AssignButton_Click"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8FB;" FontSize="16"/>
                            <TextBlock Text="Configure Assignment" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="2"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}"
                          ItemTemplate="{StaticResource LogConsoleItemTemplate}"/>
            </Grid>
        </Grid>

        <!-- Application Deployment Options Dialog -->
        <ContentDialog x:Name="AppDeployment"
                       Title="Assignment Options"
                       PrimaryButtonText="Confirm"
                       SecondaryButtonText="Cancel"
                       DefaultButton="Primary">
            <Grid MinWidth="500">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <InfoBar Grid.Row="0"
                         IsOpen="True" 
                         Severity="Informational" 
                         IsClosable="False" 
                         Message="Please configure the specific settings for the application deployment."
                         Margin="0,0,0,12"/>

                <Pivot Grid.Row="1">
                    <PivotItem Header="General">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                            <ComboBox x:Name="DeploymentModeCombo"
                                      Header="Deploy mode"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Include" />
                                <ComboBoxItem Content="Exclude" />
                            </ComboBox>
                            <ComboBox x:Name="AssignmentIntentComboBox"
                                      Header="Assignment Intent (Applications only)"
                                      PlaceholderText="Select an intent"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0"
                                      SelectionChanged="AssignmentIntentComboBox_SelectionChanged">
                                <ComboBoxItem Content="Required"/>
                                <ComboBoxItem Content="Available"/>
                                <ComboBoxItem Content="Uninstall"/>
                            </ComboBox>
                            <InfoBar x:Name="AvailableIntentInfoBar"
                                     IsOpen="False"
                                     IsClosable="False"
                                     Severity="Informational"
                                     Title="Available Assignment"
                                     Message="Please note that the 'All Devices' virtual group is not supported for the 'Available' intent."
                                     Margin="0,8,0,0"/>

                            <!-- Assignment Filter -->
                            <Expander x:Name="FilterExpander"
                                      Header="Assignment Filter"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Expanding="FilterExpander_Expanding"
                                      Collapsed="FilterExpander_Collapsed">
                                <StackPanel Spacing="12">
                                    <ComboBox x:Name="FilterSelectionComboBox"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="Select a filter..."
                                              SelectionChanged="FilterSelectionComboBox_SelectionChanged"/>
                                    <ComboBox x:Name="FilterModeComboBox"
                                              Header="Filter Mode"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0"
                                              SelectionChanged="FilterModeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Include"/>
                                        <ComboBoxItem Content="Exclude"/>
                                    </ComboBox>
                                    <InfoBar x:Name="FilterPlatformInfoBar"
                                             IsOpen="True"
                                             IsClosable="False"
                                             Severity="Warning"
                                             Title="Platform Compatibility"
                                             Message="Filters are platform specific - Please only assign one platform at a time when using filters!"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </PivotItem>

                    <PivotItem Header="Windows">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                            <ComboBox x:Name="NotificationSettingsCombo"
                                      Header="End user notifications"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Show all toast notifications" />
                                <ComboBoxItem Content="Hide all toast notifications" />
                                <ComboBoxItem Content="Hide toast notifications and show only reboot" />
                            </ComboBox>

                            <ComboBox x:Name="DeliveryOptimizationCombo"
                                      Header="Delivery Optimization priority"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Content download in background" />
                                <ComboBoxItem Content="Content download in foreground" />
                            </ComboBox>
                            <TextBlock Text="Availability and Installation deadline will be set to 'As soon as possible'" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="Restart grace period will be set to 'Disabled'" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="These settings will be made configurable in a future update." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </PivotItem>

                    <PivotItem Header="iOS">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                            <ComboBox x:Name="UseDeviceLicensingCombo"
                                      Header="Use device licensing"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="True" />
                                <ComboBoxItem Content="False" />
                            </ComboBox>
                            <ComboBox x:Name="UninstallOnDeviceRemovalCombo"
                                      Header="Uninstall on device removal"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="True" />
                                <ComboBoxItem Content="False" />
                            </ComboBox>
                            <ComboBox x:Name="IsRemovableCombo"
                                      Header="Is removable"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="True" />
                                <ComboBoxItem Content="False" />
                            </ComboBox>
                            <ComboBox x:Name="PreventManagedAppBackupCombo"
                                      Header="Prevent managed app backup"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="True" />
                                <ComboBoxItem Content="False" />
                            </ComboBox>
                            <ComboBox x:Name="PreventAutoAppUpdateCombo"
                                      Header="Prevent auto app update"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="1">
                                <ComboBoxItem Content="True" />
                                <ComboBoxItem Content="False" />
                            </ComboBox>
                        </StackPanel>
                    </PivotItem>

                    <PivotItem Header="Android">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                            <ComboBox x:Name="UpdatePriority"
                                        Header="Update priority"
                                        HorizontalAlignment="Stretch"
                                        SelectedIndex="0">
                                <ComboBoxItem Content="Default"/>
                                <ComboBoxItem Content="High priority"/>
                                <ComboBoxItem Content="Postponed"/>
                            </ComboBox>
                        </StackPanel>
                    </PivotItem>

                    <PivotItem Header="macOS">
                        <StackPanel Spacing="16" Margin="0,12,0,0">
                            <TextBlock Text="No specific settings available for macOS." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </PivotItem>
                </Pivot>
            </Grid>
        </ContentDialog>
    </Grid>
</utilities:BaseMultiTenantPage>