<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="IntuneTools.Pages.Controls.LoadingOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Acrylic loading overlay shared across pages. See XAML_STYLE_GUIDE.md §10.
        Set IsLoading="True" to show; set StatusText for the line under the spinner.
    -->
    <Border Background="{ThemeResource SystemControlAcrylicWindowBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Visibility="{x:Bind OverlayVisibility, Mode=OneWay}">
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="15">
            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                          Width="50"
                          Height="50"/>
            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        </StackPanel>
    </Border>
</UserControl>
