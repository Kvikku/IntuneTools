<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="IntuneTools.Pages.Controls.EmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    IsHitTestVisible="False">

    <!--
        Centered "no items" placeholder used inside DataGrid / ListView content areas.
        See XAML_STYLE_GUIDE.md §9.
    -->
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="6">
        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                  Glyph="{x:Bind Glyph, Mode=OneWay}"
                  Style="{StaticResource EmptyStateGlyphStyle}"/>
        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                   Style="{StaticResource EmptyStateTitleStyle}"/>
        <TextBlock Text="{x:Bind Message, Mode=OneWay}"
                   Style="{StaticResource EmptyStateMessageStyle}"/>
    </StackPanel>
</UserControl>
