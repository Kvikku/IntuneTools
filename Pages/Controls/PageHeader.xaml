<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="IntuneTools.Pages.Controls.PageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Shared page header used across all feature pages.
        See XAML_STYLE_GUIDE.md §2.

        Order is fixed: Title → Subtitle → Instruction InfoBar → ExtraContent (more InfoBars).
    -->
    <StackPanel Margin="0,0,0,16">
        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                   Style="{StaticResource PageTitleTextBlockStyle}"/>

        <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                   Style="{StaticResource PageSubtitleTextBlockStyle}"
                   Visibility="{x:Bind HasSubtitle, Mode=OneWay}"/>

        <InfoBar IsOpen="True"
                 IsClosable="True"
                 Severity="{x:Bind InstructionSeverity, Mode=OneWay}"
                 Title="{x:Bind InstructionTitle, Mode=OneWay}"
                 Message="{x:Bind InstructionText, Mode=OneWay}"
                 Margin="0,8,0,0"
                 Visibility="{x:Bind HasInstruction, Mode=OneWay}"/>

        <ContentPresenter Content="{x:Bind ExtraContent, Mode=OneWay}"/>
    </StackPanel>
</UserControl>
