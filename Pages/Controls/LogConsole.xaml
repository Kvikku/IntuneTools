<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="IntuneTools.Pages.Controls.LogConsole"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Shared log console used by every page that exposes a per-operation log.
        Owns the 58 / 18 / * column template so all pages render identically.
        See XAML_STYLE_GUIDE.md §11.

        Bind Entries to the page's LogEntries collection (provided by BaseMultiTenantPage).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Bind HeaderText, Mode=OneWay}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ListView x:Name="EntriesList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Entries, Mode=OneWay}"
                  SelectionMode="Extended">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding TimestampText}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LevelIndicator}"
                                   Foreground="{Binding Foreground}"
                                   FontSize="12"
                                   VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Message}"
                                   Foreground="{Binding Foreground}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</UserControl>
