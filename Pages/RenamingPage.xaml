<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.RenamingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    xmlns:c="using:IntuneTools.Pages.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="F"      Invoked="FocusSearch_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="L"      Invoked="ListAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="A"      Invoked="SelectAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="A" Invoked="DeselectAll_Accelerator"/>
            <KeyboardAccelerator Modifiers="Control" Key="Enter"  Invoked="PrimaryAction_Accelerator"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <c:PageHeader Grid.Row="0"
                      Title="Intune Renaming"
                      Subtitle="Bulk rename policies by adding prefixes, updating descriptions, or removing prefixes."
                      InstructionText="1. Search or list all content to populate the staging grid.  2. Choose a rename mode and enter the desired prefix / text.  3. Click 'Update' to apply the rename to every staged item.">
            <c:PageHeader.ExtraContent>
                <StackPanel>
                    <InfoBar x:Name="TenantInfoBar"
                             Severity="Informational"
                             IsClosable="False"
                             IsOpen="False"
                             Margin="0,8,0,0"/>
                    <!-- Operation Status Bar - provides visual feedback during bulk operations -->
                    <InfoBar x:Name="OperationStatusBar"
                             Severity="Informational"
                             IsClosable="True"
                             IsOpen="False"
                             Margin="0,8,0,0">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <ProgressRing x:Name="OperationProgressRing"
                                              IsActive="False"
                                              Width="20"
                                              Height="20"
                                              Visibility="Collapsed"/>
                                <ProgressBar x:Name="OperationProgressBar"
                                             Width="200"
                                             IsIndeterminate="False"
                                             Visibility="Collapsed"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                </StackPanel>
            </c:PageHeader.ExtraContent>
        </c:PageHeader>

        <!-- Toolbar Cards Row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">

            <!-- Search & Staging Card -->
            <c:ToolbarCard HeaderText="Search &amp; Staging">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <AutoSuggestBox x:Name="SearchQueryTextBox"
                                    AutomationProperties.Name="Renaming search query"
                                    PlaceholderText="Search by name..."
                                    Style="{StaticResource ToolbarSearchBoxStyle}"
                                    VerticalAlignment="Center"
                                    QuerySubmitted="SearchQueryTextBox_QuerySubmitted"/>
                    <AppBarButton x:Name="ListAllButton" AutomationProperties.Name="List all content" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items (Ctrl+L)."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                    <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    <AppBarSeparator/>
                    <AppBarButton x:Name="SelectAllButton" Label="Select All" Click="SelectAllButton_Click" ToolTipService.ToolTip="Select all items in the staging grid.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8B3;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="DeselectAllButton" Label="Deselect All" Click="DeselectAllButton_Click" ToolTipService.ToolTip="Clear the grid selection.">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE711;"/>
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <TextBlock x:Name="SelectionCountText"
                               Text="Selected: 0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="4,0,0,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </c:ToolbarCard>

            <!-- Rename Options Card -->
            <c:ToolbarCard HeaderText="Rename Configuration">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ComboBox x:Name="RenameModeComboBox"
                              Width="150"
                              SelectedIndex="0"
                              ToolTipService.ToolTip="Choose the rename mode."
                              SelectionChanged="RenameModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Add Prefix"/>
                        <ComboBoxItem Content="Description"/>
                        <ComboBoxItem Content="Remove Prefix"/>
                    </ComboBox>
                    <TextBox x:Name="NewNameTextBox"
                             PlaceholderText="Enter prefix..."
                             Width="220"
                             TextChanged="NewNameTextBox_TextChanged"/>
                    <AppBarButton x:Name="PrefixButton" Label="Format">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8D2;"/>
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel x:Name="OptionsPanel" Orientation="Vertical" MinWidth="200">
                                    <TextBlock Text="Prefix Format" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="Parentheses" Content="Parentheses (  )" GroupName="PrefixOptions" IsChecked="True" Checked="PrefixFormat_Changed"/>
                                    <RadioButton x:Name="SquareBrackets" Content="Square brackets [  ]" GroupName="PrefixOptions" Checked="PrefixFormat_Changed"/>
                                    <RadioButton x:Name="CurlyBrackets" Content="Curly brackets {  }" GroupName="PrefixOptions" Checked="PrefixFormat_Changed"/>
                                </StackPanel>
                            </Flyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    <Button x:Name="RenameButton"
                            Click="RenameButton_Click"
                            ToolTipService.ToolTip="Update all staged items (Ctrl+Enter)."
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AC;" FontSize="16"/>
                            <TextBlock Text="Update" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </c:ToolbarCard>
        </StackPanel>

        <!-- Main Content Row -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="Auto"/>
                <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="200"/>
                <!-- Log panel -->
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- InfoBar -->
                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Informational"
                         Title="Staging Area"
                         Message="This grid acts as a staging area. All items listed below will be updated. Use the 'Clear' buttons to exclude items you do not wish to update."
                         IsClosable="True"
                         Margin="0,0,12,12"/>
                
                <!-- DataGrid -->
                <controls:DataGrid Grid.Row="1"
                    x:Name="RenamingDataGrid" 
                    AutoGenerateColumns="False"
                    ItemsSource="{x:Bind CustomContentList}"
                    SelectionMode="Extended"
                    Margin="0,0,12,0"
                    IsReadOnly="True"
                    CanUserSortColumns="True"
                    CanUserReorderColumns="False"
                    Sorting="RenamingDataGrid_Sorting"
                    SelectionChanged="RenamingDataGrid_SelectionChanged">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="New Name (live preview)" Binding="{Binding PreviewName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Empty state shown when the staging grid has no items. -->
                <c:EmptyState x:Name="StagingEmptyState"
                              Grid.Row="1"
                              Glyph="&#xE8AC;"
                              Title="No items staged for renaming"
                              Message="Use Search or List All to populate the grid (Ctrl+F to focus search, Ctrl+L to list all)."
                              Margin="0,0,12,0"/>

                <!-- Loading Overlay -->
                <c:LoadingOverlay x:Name="LoadingOverlay"
                                  Grid.RowSpan="2"
                                  StatusText="Loading..."/>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <c:LogConsole Grid.Column="2"
                          x:Name="LogConsole"
                          Margin="0,-20,0,0"
                          Entries="{x:Bind LogEntries, Mode=OneWay}"/>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
