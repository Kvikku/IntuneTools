<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.JsonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Migrated to the unified UI standard (see docs/UI_STANDARD.md).
        Layout contract:
            Row 0  Header (title, subtitle, status InfoBars)
            Row 1  Toolbar cards (search/staging + JSON actions)
            Row 2  Main content (DataGrid | splitter | side panel)
    -->
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="{StaticResource PageHeaderBottomMargin}">
            <TextBlock Text="JSON Import / Export"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>
            <TextBlock Text="Export policies to JSON files for backup or offline transfer, then import them into any tenant later."
                       Style="{StaticResource PageSubtitleTextBlockStyle}"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,12,0,0"/>
            <!-- Operation Status Bar - shared UserControl -->
            <utilities:OperationStatusBar x:Name="OperationStatusBar" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ===== Toolbar Cards Row ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="{StaticResource PageSectionSpacing}" Margin="0,0,0,16">

            <!-- Search & Staging Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Search &amp; Staging"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox x:Name="InputTextBox"
                                 PlaceholderText="Enter search query..."
                                 Width="250"
                                 VerticalAlignment="Center"/>
                        <AppBarButton x:Name="SearchButton" Icon="Find" Label="Search" Click="SearchButton_Click" ToolTipService.ToolTip="Search for specific items."/>
                        <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items from the tenant."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                        <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- JSON Actions Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="JSON Actions"
                               Style="{StaticResource CardSectionLabelTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="ExportButton"
                                Click="ExportButton_Click"
                                ToolTipService.ToolTip="Export staged items to a folder. Creates one JSON file per content type (e.g. settingscatalog.json, devicecompliance.json)."
                                Style="{StaticResource PrimaryActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                                <TextBlock Text="Export to Folder" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportButton"
                                Click="ImportButton_Click"
                                ToolTipService.ToolTip="Import items from a folder containing exported JSON files. Reads all supported content type files from the selected folder."
                                Style="{StaticResource SecondaryActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="16"/>
                                <TextBlock Text="Import from Folder" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <AppBarSeparator/>
                        <Button x:Name="ImportToTenantButton"
                                Click="ImportToTenantButton_Click"
                                ToolTipService.ToolTip="Create policies in the destination tenant from the staged JSON data. Requires a destination tenant to be authenticated."
                                Style="{StaticResource SecondaryActionButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B5;" FontSize="16"/>
                                <TextBlock x:Name="ImportToTenantButtonText" Text="Import to Tenant" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== Main Content Row ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="340" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Informational"
                         Title="Staging Area"
                         Message="Load items from a tenant or JSON files. 'Export to Folder' saves them as JSON. 'Import to Tenant' creates them in the destination tenant."
                         IsClosable="True"
                         Margin="0,0,12,12"/>

                <controls:DataGrid Grid.Row="1"
                                   x:Name="JsonDataGrid"
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="JsonDataGrid_Sorting">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Loading Overlay - shared UserControl -->
                <utilities:LoadingOverlay Grid.RowSpan="2"
                                          x:Name="LoadingOverlay"/>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           Style="{StaticResource SidePanelHeaderTextBlockStyle}"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended"
                          ItemContainerStyle="{StaticResource LogListViewItemContainerStyle}"
                          ItemTemplate="{StaticResource LogConsoleItemTemplate}"/>
            </Grid>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
