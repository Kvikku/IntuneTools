<?xml version="1.0" encoding="utf-8"?>
<utilities:BaseDataOperationPage
    x:Class="IntuneTools.Pages.JsonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntuneTools.Pages"
    xmlns:utilities="using:IntuneTools.Utilities"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- CommandBar -->
            <RowDefinition Height="*"/>
            <!-- Data grid + Side panel -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="JSON Import / Export"
                       HorizontalAlignment="Left"
                       FontSize="38"
                       FontWeight="Bold"/>
            <InfoBar x:Name="TenantInfoBar"
                     Severity="Informational"
                     IsClosable="False"
                     IsOpen="False"
                     Margin="0,8,0,0"/>
            <!-- Operation Status Bar - provides visual feedback during bulk operations -->
            <InfoBar x:Name="OperationStatusBar"
                     Severity="Informational"
                     IsClosable="True"
                     IsOpen="False"
                     Margin="0,8,0,0">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressRing x:Name="OperationProgressRing"
                                      IsActive="False"
                                      Width="20"
                                      Height="20"
                                      Visibility="Collapsed"/>
                        <ProgressBar x:Name="OperationProgressBar"
                                     Width="200"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

        <!-- Toolbar Cards Row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">

            <!-- Search & Staging Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Search &amp; Staging" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox x:Name="InputTextBox"
                                 PlaceholderText="Enter search query..."
                                 Width="250"
                                 VerticalAlignment="Center"/>
                        <AppBarButton x:Name="SearchButton" Icon="Find" Label="Search" Click="SearchButton_Click" ToolTipService.ToolTip="Search for specific items."/>
                        <AppBarButton x:Name="ListAllButton" Icon="ViewAll" Label="List All" Click="ListAllButton_Click" ToolTipService.ToolTip="List all items from the tenant."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearSelectedButton" Icon="Remove" Label="Clear Selected" Click="ClearSelectedButton_Click" ToolTipService.ToolTip="Remove selected items from staging area."/>
                        <AppBarButton x:Name="ClearAllButton" Icon="Clear" Label="Clear All" Click="ClearAllButton_Click" ToolTipService.ToolTip="Clear all items from staging area."/>
                        <AppBarSeparator/>
                        <AppBarButton x:Name="ClearLogButton" Icon="Delete" Label="Clear Log" Click="ClearLogButton_Click" ToolTipService.ToolTip="Clear the log console."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- JSON Actions Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="JSON Actions" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="ExportButton"
                                Click="ExportButton_Click"
                                ToolTipService.ToolTip="Export all staged items to a JSON file."
                                Height="40"
                                Padding="16,0"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                                <TextBlock Text="Export to JSON" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportButton"
                                Click="ImportButton_Click"
                                ToolTipService.ToolTip="Import items from a JSON file into the staging area."
                                Height="40"
                                Padding="16,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="16"/>
                                <TextBlock Text="Import from JSON" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Main Content Row -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- DataGrid -->
                <ColumnDefinition Width="Auto"/>
                <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="200"/>
                <!-- Log panel -->
            </Grid.ColumnDefinitions>

            <!-- DataGrid with InfoBar and loading overlay -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- InfoBar -->
                <InfoBar Grid.Row="0"
                         IsOpen="True"
                         Severity="Informational"
                         Title="Staging Area"
                         Message="Use 'List All' or 'Search' to load items from the tenant, or 'Import from JSON' to load from a file. Then use 'Export to JSON' to save all staged items."
                         IsClosable="True"
                         Margin="0,0,12,12"/>
                
                <!-- DataGrid -->
                <controls:DataGrid Grid.Row="1"
                                   x:Name="JsonDataGrid" 
                                   AutoGenerateColumns="False"
                                   SelectionMode="Extended"
                                   Margin="0,0,12,0"
                                   IsReadOnly="True"
                                   CanUserSortColumns="True"
                                   CanUserReorderColumns="False"
                                   Sorting="JsonDataGrid_Sorting">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Name" Binding="{Binding ContentName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Type" Binding="{Binding ContentType}" Width="*"/>
                        <controls:DataGridTextColumn Header="Platform" Binding="{Binding ContentPlatform}" Width="*"/>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ContentId}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Description" Binding="{Binding ContentDescription}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="2"
                        x:Name="LoadingOverlay"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                        Visibility="Collapsed"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="15">
                        <ProgressRing x:Name="LoadingProgressRing"
                                      IsActive="True"
                                      Width="50"
                                      Height="50"/>
                        <TextBlock x:Name="LoadingStatusText"
                                   Text="Loading..."
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Resizable Splitter -->
            <sizers:GridSplitter Grid.Column="1"
                                 Width="8"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Columns"
                                 Background="Transparent"/>

            <!-- Log Console Panel -->
            <Grid Grid.Column="2"
                  Margin="0,-20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Log Console"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView Grid.Row="1"
                          x:Name="LogConsole"
                          SelectionMode="Extended">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimestampText}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LevelIndicator}"
                                           Foreground="{Binding Foreground}"
                                           FontSize="12"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Foreground}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</utilities:BaseDataOperationPage>
