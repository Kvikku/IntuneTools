<?xml version="1.0" encoding="utf-8"?>
<!--
    Unified UI standard for IntuneTools pages.

    See docs/UI_STANDARD.md for the full design guidance and rollout status.
    Pages should consume these named styles instead of hard-coding sizes,
    paddings, brushes, etc. so the look stays consistent as we modernize.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Spacing & sizing tokens =====
         Centralised so we can tune the whole app from one place. -->
    <Thickness x:Key="PageRootMargin">24,24,24,24</Thickness>
    <Thickness x:Key="PageHeaderBottomMargin">0,0,0,20</Thickness>
    <x:Double x:Key="PageSectionSpacing">12</x:Double>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <Thickness x:Key="CardPadding">16,12,16,12</Thickness>

    <!-- ===== Typography =====
         Page title: Fluent "Title" type ramp - lighter than the previous 38/Bold,
         keeps a confident hierarchy without dominating the content area. -->
    <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
    </Style>

    <!-- Page subtitle / one-line description under the title. -->
    <Style x:Key="PageSubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Section heading inside a toolbar / config card. -->
    <Style x:Key="CardSectionLabelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Style>

    <!-- Heading for a side panel (Log Console, Groups, etc.). -->
    <Style x:Key="SidePanelHeaderTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- Big numeric value inside a summary stat card (Total Events, Unique
         Actors, etc.). Pairs with CardSectionLabelTextBlockStyle as the
         small caption above it. -->
    <Style x:Key="StatValueTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
    </Style>

    <!-- ===== Surfaces =====
         Standard card used for toolbars and configuration groups. -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
    </Style>

    <!-- ===== Action buttons =====
         All primary/destructive actions should be the same height/shape so the
         toolbar reads as a single row. Use FontIcon + TextBlock content. -->
    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="16,0,16,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="16,0,16,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Destructive actions (Delete, etc.). Keeps the same shape but uses the
         system "critical" colour so it reads as dangerous in both themes. -->
    <Style x:Key="DestructiveActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="16,0,16,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ===== Log console ===== -->
    <Style x:Key="LogTimestampTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="LogLevelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="LogMessageTextBlockStyle" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="LogListViewItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="4,2,4,2"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- ===== Loading overlay =====
         Shared status text used by every data page's LoadingOverlay so the
         spinner caption looks the same everywhere. -->
    <Style x:Key="LoadingStatusTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
    </Style>

    <!-- ===== Section / sub-section headings =====
         Larger heading used for prominent in-card section titles
         (e.g. "Source Tenant", "Destination Tenant" on SettingsPage). -->
    <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
    </Style>

    <!-- Smaller sub-section label used inside flyouts and grouped option
         lists (e.g. "Prefix Format", "Content Types"). Sits between the
         12 / SemiBold caption and the 16 / SemiBold side-panel header. -->
    <Style x:Key="SubsectionLabelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ===== Home page feature cards =====
         The HomePage "Get started" tiles are clickable Buttons styled to
         look like cards. They use the same surface treatment as
         CardBorderStyle but with a slightly larger Padding so the icon /
         title / description stack has room to breathe. -->
    <Style x:Key="FeatureCardButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="FeatureCardTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="FeatureCardDescriptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Opacity" Value="0.65"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ===== Stat / dashboard widgets (HomePage) ===== -->
    <Style x:Key="StatHeroValueTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="40"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatHeroLabelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatBreakdownValueTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="StatBreakdownLabelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- Muted caption used for small, low-emphasis labels next to a value
         (e.g. the "Tenant" label above the tenant name on HomePage, or
         the "Estimate based on..." footnote under the time-saved widget). -->
    <Style x:Key="MutedCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>

</ResourceDictionary>
