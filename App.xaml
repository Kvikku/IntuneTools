<?xml version="1.0" encoding="utf-8"?>
<Application  
    x:Class="IntuneTools.App"  
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
    xmlns:local="using:IntuneTools">  
    <Application.Resources>  
        <ResourceDictionary>  
            <ResourceDictionary.MergedDictionaries>  
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />  
                <!-- Other merged dictionaries here -->  
            </ResourceDictionary.MergedDictionaries>  
            <!-- Other app resources here -->  

            <Style x:Key="FlyoutPresenterStyle" TargetType="FlyoutPresenter">  
                <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"/>  
                <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundChromeHighBrush}"/>  
                <Setter Property="BorderThickness" Value="1"/>  
            </Style>

            <!-- ===== Shared UX design tokens ===== -->
            <!-- Used by version status indicators, tenant pill dots, etc. so dark/light themes both work. -->
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="#107C10"/>
            <SolidColorBrush x:Key="StatusWarningBrush" Color="#C29200"/>
            <SolidColorBrush x:Key="StatusDangerBrush"  Color="#C42B1C"/>
            <SolidColorBrush x:Key="StatusNeutralBrush" Color="#808080"/>

            <!-- Primary action button: consistent height + weight across data-operation pages. -->
            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <!-- Destructive action button: same shape as primary but uses the danger brush. -->
            <Style x:Key="DestructiveActionButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                <Setter Property="Background" Value="{ThemeResource StatusDangerBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource StatusDangerBrush}"/>
            </Style>

            <!-- Page heading typography. -->
            <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="38"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
            <Style x:Key="PageSubtitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
            </Style>

            <!-- Tenant status pill: shared shape used by Settings + MainWindow. The Background is
                 set per-instance to the appropriate status brush (success / warning / danger). -->
            <Style x:Key="TenantStatusPillStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            </Style>

            <!-- Toolbar card: the Border container used for "Search & Staging", action cards, etc.
                 See XAML_STYLE_GUIDE.md §1. Pages should prefer the ToolbarCard UserControl. -->
            <Style x:Key="ToolbarCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12,8"/>
            </Style>

            <!-- Standard search input across all data pages. See XAML_STYLE_GUIDE.md §6. -->
            <Style x:Key="ToolbarSearchBoxStyle" TargetType="AutoSuggestBox">
                <Setter Property="Width" Value="280"/>
                <Setter Property="QueryIcon" Value="Find"/>
            </Style>

            <!-- Section label inside a ToolbarCard ("Search & Staging", "JSON Actions", etc.). -->
            <Style x:Key="SectionLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Style>

            <!-- Empty-state visual elements. See XAML_STYLE_GUIDE.md §9. -->
            <Style x:Key="EmptyStateGlyphStyle" TargetType="FontIcon">
                <Setter Property="FontSize" Value="32"/>
                <Setter Property="Opacity" Value="0.5"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.75"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="EmptyStateMessageStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="TextWrapping" Value="WrapWholeWords"/>
                <Setter Property="MaxWidth" Value="380"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
            </Style>

            <!-- Stat tile typography (e.g., AuditLogPage summary cards). -->
            <Style x:Key="StatCardLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Style>
            <Style x:Key="StatCardValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

        </ResourceDictionary>  
    </Application.Resources>  
</Application>
